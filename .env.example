# ============================================================
# FERMETRACK — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS COMMITTER le fichier .env dans Git
# ============================================================

# Supabase — récupérez ces valeurs dans votre tableau de bord Supabase
# Project Settings > API
VITE_SUPABASE_URL=https://VOTRE-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Notifications Push (PWA) — optionnel mais recommandé
# Générez vos clés VAPID sur : https://web-push-codelab.glitch.me/
# Ou en ligne de commande : npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=VOTRE_CLE_VAPID_PUBLIQUE
